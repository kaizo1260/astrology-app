{
  "buildCommand": "cd Astrologer && pip install -e . && cd ..",
  "outputDirectory": ".",
  "installCommand": "pip install -r requirements.txt",
  "env": {
    "ENV_TYPE": "production",
    "LOG_LEVEL": "INFO"
  },
  "functions": {
    "api/**": {
      "runtime": "python3.11"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api"
    }
  ]
}
